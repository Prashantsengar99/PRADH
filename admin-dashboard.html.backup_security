    async function updateOrderStatus(orderId, newStatus) {
        if (!confirm(`Update order ${orderId} status to "${newStatus}"?`)) return;
        
        try {
            const response = await fetch(`/api/orders/${orderId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: newStatus })
            });
            const data = await response.json();
            if (data.success) {
                alert(`✅ Order ${orderId} status updated!`);
                loadOrders();
                loadDashboard();
            }
        } catch (error) {
            console.error('Error updating order:', error);
        }
    }

    // ============================================
    // COUPONS
    // ============================================
    async function loadCoupons() {
        try {
            const response = await fetch('/api/coupons');
            const data = await response.json();
            const tbody = document.getElementById('couponsTableBody');
            
            if (data.success && data.coupons && data.coupons.length > 0) {
                tbody.innerHTML = data.coupons.map(c => {
                    const isExpired = c.expiry ? new Date(c.expiry) < new Date() : false;
                    return `
                        <tr>
                            <td><span style="color: #facc15; font-weight: 700;">${c.code}</span></td>
                            <td style="color: #22c55e; font-weight: 600;">${c.discount}%</td>
                            <td style="color: #94a3b8;">${c.expiry || 'No expiry'}</td>
                            <td><span class="status-badge ${isExpired ? 'status-inactive' : 'status-active'}">${isExpired ? 'Expired' : 'Active'}</span></td>
                            <td><button class="btn-danger" onclick="deleteCoupon('${c.code}')" style="padding: 4px 12px;"><i class="fas fa-trash"></i></button></td>
                        </tr>
                    `;
                }).join('');
            }
        } catch (error) {
            console.error('Error loading coupons:', error);
        }
    }

    function showAddCouponModal() {
        document.getElementById('couponModal').classList.add('show');
    }

    async function saveCoupon(event) {
        event.preventDefault();
        const code = document.getElementById('couponCode').value.trim().toUpperCase();
        const discount = document.getElementById('couponDiscount').value.trim();
        const expiry = document.getElementById('couponExpiry').value;
        
        if (!code || !discount) {
            alert('Please fill all fields');
            return;
        }
        
        try {
            const response = await fetch('/api/coupons', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ code, discount: parseInt(discount), expiry })
            });
            const data = await response.json();
            if (data.success) {
                alert('✅ Coupon created!');
                closeModal('couponModal');
                loadCoupons();
                loadDashboard();
            }
        } catch (error) {
            console.error('Error creating coupon:', error);
        }
    }

    async function deleteCoupon(code) {
        if (!confirm(`Delete coupon "${code}"?`)) return;
        try {
            const response = await fetch(`/api/coupons/${code}`, { method: 'DELETE' });
            const data = await response.json();
            if (data.success) {
                alert('✅ Coupon deleted!');
                loadCoupons();
                loadDashboard();
            }
        } catch (error) {
            console.error('Error deleting coupon:', error);
        }
    }

    // ============================================
    // REVIEWS
    // ============================================
    async function loadReviews() {
        try {
            const response = await fetch('/api/reviews');
            const data = await response.json();
            const tbody = document.getElementById('reviewsTableBody');
            
            if (data.success && data.reviews && data.reviews.length > 0) {
                document.getElementById('reviewBadge').textContent = data.reviews.filter(r => r.status === 'pending').length;
                tbody.innerHTML = data.reviews.map(r => `
                    <tr>
                        <td style="color: #94a3b8;">${r.productName || 'Product'}</td>
                        <td>${r.userName || 'Anonymous'}</td>
                        <td style="color: #facc15;">${'★'.repeat(r.rating)}</td>
                        <td style="color: #94a3b8; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${r.comment}</td>
                        <td><span class="status-badge status-${r.status}">${r.status}</span></td>
                        <td>
                            ${r.status === 'pending' ? `
                                <button class="btn-success" onclick="updateReviewStatus('${r.id}', 'approved')" style="padding: 4px 8px; font-size: 11px; margin-right: 4px;">Approve</button>
                                <button class="btn-danger" onclick="updateReviewStatus('${r.id}', 'rejected')" style="padding: 4px 8px; font-size: 11px;">Reject</button>
                            ` : `

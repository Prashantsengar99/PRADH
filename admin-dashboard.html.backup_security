    async function updateReviewStatus(reviewId, status) {
        if (!confirm(`Are you sure you want to ${status} this review?`)) return;
        try {
            const response = await fetch(`/api/reviews/${reviewId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });
            const data = await response.json();
            if (data.success) {
                alert(`✅ Review ${status} successfully!`);
                loadReviews();
            }
        } catch (error) {
            console.error('Error updating review:', error);
        }
    }

    async function deleteReview(reviewId) {
        if (!confirm('Delete this review?')) return;
        try {
            const response = await fetch(`/api/reviews/${reviewId}`, { method: 'DELETE' });
            const data = await response.json();
            if (data.success) {
                alert('✅ Review deleted!');
                loadReviews();
            }
        } catch (error) {
            console.error('Error deleting review:', error);
        }
    }

    // ============================================
    // CUSTOMERS
    // ============================================
    async function loadCustomers() {
        try {
            const response = await fetch('/get-orders');
            const data = await response.json();
            const tbody = document.getElementById('customersTableBody');
            
            if (data.success && data.orders && data.orders.length > 0) {
                const customerMap = new Map();
                data.orders.forEach(order => {
                    if (order.customer && order.customer.phone) {
                        const phone = order.customer.phone;
                        if (!customerMap.has(phone)) {
                            customerMap.set(phone, {
                                name: order.customer.name || 'Guest',
                                email: order.customer.email || 'N/A',
                                phone: order.customer.phone,
                                orders: 0,
                                totalSpent: 0
                            });
                        }
                        const customer = customerMap.get(phone);
                        customer.orders += 1;
                        customer.totalSpent += parseFloat(order.total) || 0;
                    }
                });
                
                const customers = Array.from(customerMap.values());
                document.getElementById('customerBadge').textContent = customers.length;
                
                if (customers.length > 0) {
                    customers.sort((a, b) => b.totalSpent - a.totalSpent);
                    tbody.innerHTML = customers.map(c => {
                        let status = 'Active', statusClass = 'status-active';
                        if (c.totalSpent > 5000) { status = 'VIP'; statusClass = 'status-vip'; }
                        else if (c.totalSpent > 1000) { status = 'Regular'; statusClass = 'status-active'; }
                        return `
                            <tr>
                                <td><strong>${c.name}</strong></td>
                                <td style="color: #94a3b8;">${c.email}</td>
                                <td style="color: #94a3b8;">${c.phone}</td>
                                <td style="color: #facc15;">${c.orders}</td>
                                <td style="color: #facc15; font-weight: 600;">₹${c.totalSpent.toFixed(2)}</td>
                                <td><span class="status-badge ${statusClass}">${status}</span></td>
                            </tr>
                        `;
                    }).join('');
                } else {
                    tbody.innerHTML = `<tr><td colspan="6" style="text-align: center; color: #64748b; padding: 40px;">No customers</td></tr>`;
                }
            }
        } catch (error) {
            console.error('Error loading customers:', error);
        }
    }

    // ============================================
    // DASHBOARD
    // ============================================
    async function loadDashboard() {
        try {
            const productResponse = await fetch('/api/admin/products');
            const productData = await productResponse.json();
            if (productData.success) {
                document.getElementById('totalProducts').textContent = productData.products.length;
            }
            
            const orderResponse = await fetch('/get-orders');
            const orderData = await orderResponse.json();
            if (orderData.success && orderData.orders) {
                const orders = orderData.orders;
                document.getElementById('totalOrders').textContent = orders.length;
                document.getElementById('orderBadge').textContent = orders.length;
                
                const revenue = orders.reduce((sum, o) => sum + (parseFloat(o.total) || 0), 0);
                document.getElementById('totalRevenue').textContent = '₹' + revenue.toFixed(2);
                
                const uniqueCustomers = new Set();
                orders.forEach(o => {
                    if (o.customer && o.customer.phone) {
                        uniqueCustomers.add(o.customer.phone);
                    }
                });
                document.getElementById('totalCustomers').textContent = uniqueCustomers.size;
                document.getElementById('customerBadge').textContent = uniqueCustomers.size;
                
                const recent = orders.slice(-5).reverse();
                const recentHtml = recent.length > 0 ? recent.map(o => `
                    <div style="display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #334155;">
                        <div>
                            <span style="color: #facc15;">#${o.id || o.order_id}</span>
                            <span style="color: #94a3b8; font-size: 13px; margin-left: 10px;">${o.customer?.name || 'Guest'}</span>
                        </div>
                        <div>
                            <span style="color: #facc15; font-weight: 600;">₹${(o.total || 0).toFixed(2)}</span>
                            <span class="status-badge status-${o.status || 'pending'}">${o.status || 'Pending'}</span>
                        </div>
                    </div>
                `).join('') : '<p style="color: #64748b;">No orders yet</p>';
                document.getElementById('recentOrders').innerHTML = recentHtml;
            }
            
            const reviewResponse = await fetch('/api/reviews');
            const reviewData = await reviewResponse.json();
            if (reviewData.success) {
                document.getElementById('reviewBadge').textContent = reviewData.reviews.filter(r => r.status === 'pending').length;
            }
        } catch (error) {
            console.error('Dashboard error:', error);
        }
    }

    // ============================================
    // INITIALIZATION
    // ============================================
    document.addEventListener('DOMContentLoaded', function() {
        if (!localStorage.getItem('adminLoggedIn')) {
            window.location.href = 'admin.html';
            return;
        }
        console.log('🛡️ PRADH Admin Panel Loaded');
        loadDashboard();
        loadProducts();
        loadOrders();
        loadCoupons();
        loadReviews();
        loadCustomers();
    });
</script>
</body>
</html>


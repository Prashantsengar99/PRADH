<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PRADH Admin Panel</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0f172a;
            color: #e2e8f0;
        }
        .admin-wrapper { display: flex; min-height: 100vh; }
        .sidebar {
            width: 260px;
            background: #1e293b;
            border-right: 1px solid #334155;
            padding: 20px;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
            z-index: 1000;
        }
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding-bottom: 20px;
            border-bottom: 1px solid #334155;
            margin-bottom: 20px;
        }
        .sidebar-brand img { height: 40px; width: auto; }
        .sidebar-brand h2 { color: #facc15; font-size: 20px; }
        .sidebar-brand span { color: #94a3b8; font-size: 12px; display: block; }
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            color: #94a3b8;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s;
            margin-bottom: 4px;
        }
        .nav-item:hover { background: #334155; color: #ffffff; }
        .nav-item.active { background: #facc15; color: #0f172a; }
        .nav-item i { width: 20px; }
        .nav-item .badge {
            margin-left: auto;
            background: #ef4444;
            color: white;
            padding: 2px 10px;
            border-radius: 12px;
            font-size: 11px;
        }
        .main-content {
            margin-left: 260px;
            flex: 1;
            padding: 30px;
            min-height: 100vh;
        }
        .page-section { display: none; animation: fadeIn 0.3s ease; }
        .page-section.active { display: block; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .stat-card {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 16px;
            padding: 24px;
            transition: all 0.3s;
        }
        .stat-card:hover { border-color: #facc15; transform: translateY(-4px); }
        .stat-card .stat-icon { font-size: 32px; color: #facc15; margin-bottom: 12px; }
        .stat-card .stat-value { font-size: 28px; font-weight: 700; color: #ffffff; }
        .stat-card .stat-label { color: #94a3b8; font-size: 14px; }
        .table-container {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 16px;
            overflow: hidden;
        }
        .table-container table { width: 100%; border-collapse: collapse; }
        .table-container th {
            background: #0f172a;
            color: #94a3b8;
            font-weight: 600;
            font-size: 12px;
            text-transform: uppercase;
            padding: 16px 20px;
            text-align: left;
            border-bottom: 1px solid #334155;
        }
        .table-container td {
            padding: 14px 20px;
            border-bottom: 1px solid #334155;
            color: #e2e8f0;
        }
        .table-container tr:hover td { background: #0f172a; }
        .btn-primary {
            background: #facc15;
            color: #0f172a;
            padding: 10px 24px;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        .btn-primary:hover { background: #eab308; transform: translateY(-2px); box-shadow: 0 4px 15px rgba(250, 204, 21, 0.3); }
        .btn-danger {
            background: #ef4444;
            color: white;
            padding: 8px 16px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
        }
        .btn-danger:hover { background: #dc2626; }
        .btn-success {
            background: #22c55e;
            color: #0f172a;
            padding: 8px 16px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
        }
        .btn-success:hover { background: #16a34a; }
        .btn-warning {
            background: #f59e0b;
            color: #0f172a;
            padding: 8px 16px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
        }
        .btn-warning:hover { background: #d97706; }
        .btn-info {
            background: #3b82f6;
            color: white;
            padding: 8px 16px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
        }
        .btn-info:hover { background: #2563eb; }
        .status-badge {
            padding: 4px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            display: inline-block;
        }
        .status-active { background: #22c55e; color: #0f172a; }
        .status-inactive { background: #ef4444; color: white; }
        .status-vip { background: #8b5cf6; color: white; }
        .status-low-stock { background: #f59e0b; color: #0f172a; }
        .status-paid { background: #22c55e; color: #0f172a; }
        .status-pending { background: #facc15; color: #0f172a; }
        .status-shipped { background: #3b82f6; color: white; }
        .status-delivered { background: #8b5cf6; color: white; }
        .status-cancelled { background: #ef4444; color: white; }
        .mobile-toggle {
            display: none;
            background: #1e293b;
            color: #facc15;
            border: 1px solid #334155;
            padding: 10px 16px;
            border-radius: 10px;
            cursor: pointer;
            margin-bottom: 20px;
            font-size: 20px;
        }
        .product-img-thumb {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 8px;
            border: 1px solid #334155;
        }
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.7);
            z-index: 2000;
            justify-content: center;
            align-items: center;
        }
        .modal-overlay.show { display: flex; }
        .modal-content {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 20px;
            padding: 30px;
            max-width: 700px;
            width: 90%;
            max-height: 90vh;
            overflow-y: auto;
        }
        .modal-content h3 { color: #facc15; margin-bottom: 20px; }
        .modal-close {
            float: right;
            background: none;
            border: none;
            color: #94a3b8;
            font-size: 24px;
            cursor: pointer;
        }
        .modal-close:hover { color: #ffffff; }
        .detail-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin: 15px 0;
        }
        .detail-item {
            background: #0f172a;
            padding: 12px 16px;
            border-radius: 8px;
            border: 1px solid #334155;
        }
        .detail-item .label {
            color: #94a3b8;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .detail-item .value {
            color: #ffffff;
            font-size: 14px;
            font-weight: 500;
            margin-top: 4px;
            word-break: break-word;
        }
        .detail-item .value.gold { color: #facc15; }
        .order-items-list {
            margin: 15px 0;
            background: #0f172a;
            border-radius: 8px;
            padding: 10px;
            border: 1px solid #334155;
        }
        .order-items-list .item-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid #1e293b;
            color: #e2e8f0;
            font-size: 14px;
        }
        .order-items-list .item-row:last-child { border-bottom: none; }
        .order-items-list .item-row .item-name {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .order-items-list .item-row .item-name .qty-badge {
            background: #facc15;
            color: #0f172a;
            padding: 0 10px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: 700;
        }
        .order-items-list .item-row .item-price {
            color: #facc15;
            font-weight: 600;
        }
        @media (max-width: 1024px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .main-content { margin-left: 0; padding: 20px; }
            .mobile-toggle { display: inline-block; }
        }
        @media (max-width: 768px) {
            .stat-grid { grid-template-columns: 1fr 1fr !important; }
            .main-content { padding: 12px; }
            .table-container { overflow-x: auto; }
            .detail-grid { grid-template-columns: 1fr; }
        }
        .sidebar::-webkit-scrollbar { width: 4px; }
        .sidebar::-webkit-scrollbar-track { background: #1e293b; }
        .sidebar::-webkit-scrollbar-thumb { background: #facc15; border-radius: 10px; }
    </style>
</head>
<body>

<div class="admin-wrapper">
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <img src="logo.jpeg" alt="PRADH">
            <div>
                <h2>PRADH</h2>
                <span>Admin Panel</span>
            </div>
        </div>
        <nav>
            <div class="nav-item active" onclick="navigateTo('dashboard')">
                <i class="fas fa-chart-pie"></i> Dashboard
            </div>
            <div class="nav-item" onclick="navigateTo('products')">
                <i class="fas fa-box"></i> Products
                <span class="badge" id="productBadge">0</span>
            </div>
            <div class="nav-item" onclick="navigateTo('orders')">
                <i class="fas fa-shopping-bag"></i> Orders
                <span class="badge" id="orderBadge">0</span>
            </div>
            <div class="nav-item" onclick="navigateTo('coupons')">
                <i class="fas fa-ticket-alt"></i> Coupons
            </div>
            <div class="nav-item" onclick="navigateTo('reviews')">
                <i class="fas fa-star"></i> Reviews
                <span class="badge" id="reviewBadge">0</span>
            </div>
            <div class="nav-item" onclick="navigateTo('customers')">
                <i class="fas fa-users"></i> Customers
                <span class="badge" id="customerBadge">0</span>
            </div>
            <div class="nav-item" onclick="logout()" style="margin-top: 20px; border-top: 1px solid #334155; padding-top: 16px; color: #ef4444;">
                <i class="fas fa-sign-out-alt"></i> Logout
            </div>
        </nav>
    </aside>

    <main class="main-content">
        <button class="mobile-toggle" onclick="toggleSidebar()">
            <i class="fas fa-bars"></i>
        </button>

        <section id="dashboard" class="page-section active">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
                <div>
                    <h1 style="font-size: 28px; font-weight: 700;">Dashboard</h1>
                    <p style="color: #94a3b8;">Welcome to PRADH Admin Panel</p>
                </div>
                <button class="btn-primary" onclick="window.location.reload()">
                    <i class="fas fa-sync"></i> Refresh
                </button>
            </div>
            
            <div class="stat-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 30px;">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-box"></i></div>
                    <div class="stat-value" id="totalProducts">0</div>
                    <div class="stat-label">Total Products</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-shopping-bag"></i></div>
                    <div class="stat-value" id="totalOrders">0</div>
                    <div class="stat-label">Total Orders</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-rupee-sign"></i></div>
                    <div class="stat-value" id="totalRevenue">₹0</div>
                    <div class="stat-label">Total Revenue</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-users"></i></div>
                    <div class="stat-value" id="totalCustomers">0</div>
                    <div class="stat-label">Total Customers</div>
                </div>
            </div>
            
            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 20px;">
                <div class="table-container">
                    <div style="padding: 20px; border-bottom: 1px solid #334155;">
                        <h3>Recent Orders</h3>
                    </div>
                    <div style="padding: 20px;" id="recentOrders">
                        <p style="color: #64748b;">No recent orders</p>
                    </div>
                </div>
                <div class="stat-card" style="border-color: #facc15;">
                    <h3 style="color: #facc15; margin-bottom: 15px;">Quick Actions</h3>
                    <button onclick="navigateTo('products')" class="btn-primary" style="width: 100%; margin-bottom: 10px;">
                        <i class="fas fa-plus"></i> Add Product
                    </button>
                    <button onclick="navigateTo('coupons')" class="btn-primary" style="width: 100%; background: #8b5cf6; color: white;">
                        <i class="fas fa-ticket-alt"></i> Create Coupon
                    </button>
                    <button onclick="navigateTo('orders')" class="btn-primary" style="width: 100%; background: #3b82f6; color: white;">
                        <i class="fas fa-eye"></i> View Orders
                    </button>
                </div>
            </div>
        </section>

        <section id="products" class="page-section">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 10px;">
                <div>
                    <h1 style="font-size: 24px; font-weight: 700;">📦 Product Management</h1>
                    <p style="color: #94a3b8;">Add, edit, and manage your products</p>
                </div>
                <button class="btn-primary" onclick="showAddProductModal()">
                    <i class="fas fa-plus"></i> Add New Product
                </button>
            </div>
            
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Product</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Category</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="productsTableBody">
                        <tr><td colspan="7" style="text-align: center; color: #64748b; padding: 40px;">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section id="orders" class="page-section">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <div>
                    <h1 style="font-size: 24px; font-weight: 700;">🚚 Orders</h1>
                    <p style="color: #94a3b8;">View and manage customer orders</p>
                </div>
                <button class="btn-primary" onclick="loadOrders()">
                    <i class="fas fa-sync"></i> Refresh
                </button>
            </div>
            
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Order ID</th>
                            <th>Customer</th>
                            <th>Phone</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="ordersTableBody">
                        <tr><td colspan="8" style="text-align: center; color: #64748b; padding: 40px;">Loading orders...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section id="coupons" class="page-section">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <div>
                    <h1 style="font-size: 24px; font-weight: 700;">🎟️ Coupons</h1>
                    <p style="color: #94a3b8;">Manage discount coupons</p>
                </div>
                <button class="btn-primary" onclick="showAddCouponModal()">
                    <i class="fas fa-plus"></i> Create Coupon
                </button>
            </div>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Discount</th>
                            <th>Expiry</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="couponsTableBody">
                        <tr><td colspan="5" style="text-align: center; color: #64748b; padding: 40px;">No coupons</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section id="reviews" class="page-section">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <div>
                    <h1 style="font-size: 24px; font-weight: 700;">⭐ Reviews</h1>
                    <p style="color: #94a3b8;">Manage customer reviews</p>
                </div>
                <button class="btn-primary" onclick="loadReviews()">
                    <i class="fas fa-sync"></i> Refresh
                </button>
            </div>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Customer</th>
                            <th>Rating</th>
                            <th>Comment</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="reviewsTableBody">
                        <tr><td colspan="6" style="text-align: center; color: #64748b; padding: 40px;">No reviews</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section id="customers" class="page-section">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <div>
                    <h1 style="font-size: 24px; font-weight: 700;">👥 Customers</h1>
                    <p style="color: #94a3b8;">Manage your customer base</p>
                </div>
                <button class="btn-primary" onclick="loadCustomers()">
                    <i class="fas fa-sync"></i> Refresh
                </button>
            </div>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Orders</th>
                            <th>Total Spent</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="customersTableBody">
                        <tr><td colspan="6" style="text-align: center; color: #64748b; padding: 40px;">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</div>

<!-- Order Details Modal -->
<div class="modal-overlay" id="orderModal">
    <div class="modal-content">
        <button class="modal-close" onclick="closeModal('orderModal')">&times;</button>
        <h3><i class="fas fa-receipt"></i> Order Details</h3>
        <div id="orderDetailsBody">
            <p style="color: #64748b;">Loading...</p>
        </div>
    </div>
</div>

<!-- Add/Edit Product Modal -->
<div class="modal-overlay" id="productModal">
    <div class="modal-content">
        <button class="modal-close" onclick="closeModal('productModal')">&times;</button>
        <h3 id="productModalTitle">Add New Product</h3>
        <form id="productForm" onsubmit="saveProduct(event)">
            <input type="hidden" id="productId">
            <div style="margin-bottom: 15px;">
                <label class="form-label">Product Name *</label>
                <input type="text" id="prodName" class="form-input" placeholder="Enter product name" required>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
                <div>
                    <label class="form-label">Price (₹) *</label>
                    <input type="number" id="prodPrice" class="form-input" placeholder="0" required>
                </div>
                <div>
                    <label class="form-label">Stock</label>
                    <input type="number" id="prodStock" class="form-input" placeholder="0">
                </div>
            </div>
            <div style="margin-bottom: 15px;">
                <label class="form-label">Max Purchase Per User (0 = Unlimited)</label>
                <input type="number" id="prodMaxPurchase" class="form-input" placeholder="0" min="0">
                <small style="color: #64748b; display: block; margin-top: 4px;">0 = Unlimited | 1 = Once | 2 = Twice</small>
            </div>
            <div style="margin-bottom: 15px;">
                <label class="form-label">Category</label>
                <input type="text" id="prodCategory" class="form-input" placeholder="e.g., Whey Protein">
            </div>
            <div style="margin-bottom: 15px;">
                <label class="form-label">Description</label>
                <textarea id="prodDescription" class="form-input" rows="3" placeholder="Product description"></textarea>
            </div>
            <div style="margin-bottom: 15px;">
                <label class="form-label">Image URL</label>
                <input type="text" id="prodImage" class="form-input" placeholder="product.jpeg">
            </div>
            <div style="display: flex; gap: 10px;">
                <button type="submit" class="btn-primary" style="flex: 1;">
                    <i class="fas fa-save"></i> Save Product
                </button>
                <button type="button" class="btn-danger" onclick="closeModal('productModal')">Cancel</button>
            </div>
        </form>
    </div>
</div>

<!-- Add Coupon Modal -->
<div class="modal-overlay" id="couponModal">
    <div class="modal-content">
        <button class="modal-close" onclick="closeModal('couponModal')">&times;</button>
        <h3>Create Coupon</h3>
        <form onsubmit="saveCoupon(event)">
            <div style="margin-bottom: 15px;">
                <label class="form-label">Coupon Code *</label>
                <input type="text" id="couponCode" class="form-input" placeholder="e.g., DESIFUEL20" required>
            </div>
            <div style="margin-bottom: 15px;">
                <label class="form-label">Discount (%) *</label>
                <input type="number" id="couponDiscount" class="form-input" placeholder="10" required>
            </div>
            <div style="margin-bottom: 15px;">
                <label class="form-label">Expiry Date</label>
                <input type="date" id="couponExpiry" class="form-input">
            </div>
            <div style="display: flex; gap: 10px;">
                <button type="submit" class="btn-primary" style="flex: 1;">
                    <i class="fas fa-plus"></i> Create Coupon
                </button>
                <button type="button" class="btn-danger" onclick="closeModal('couponModal')">Cancel</button>
            </div>
        </form>
    </div>
</div>

<script>
    (function() {
        if (localStorage.getItem(.adminLoggedIn.) !== .true.) {
            window.location.href = .admin.html.;
        }
    })();

    // ============================================
    // NAVIGATION
    // ============================================
    function navigateTo(section) {
        document.querySelectorAll('.page-section').forEach(el => el.classList.remove('active'));
        document.getElementById(section).classList.add('active');
        document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
        
        const navMap = {
            'dashboard': 0, 'products': 1, 'orders': 2, 'coupons': 3, 'reviews': 4, 'customers': 5
        };
        const navItems = document.querySelectorAll('.nav-item');
        if (navMap[section] !== undefined) {
            navItems[navMap[section]]?.classList.add('active');
        }
        
        document.getElementById('sidebar').classList.remove('open');
        
        if (section === 'products') loadProducts();
        if (section === 'orders') loadOrders();
        if (section === 'coupons') loadCoupons();
        if (section === 'reviews') loadReviews();
        if (section === 'dashboard') loadDashboard();
        if (section === 'customers') loadCustomers();
    }

    function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('open');
    }

    function logout() {
        if (confirm('Are you sure you want to logout?')) {
            localStorage.removeItem('adminLoggedIn');
            window.location.href = 'admin.html';
        }
    }

    function closeModal(modalId) {
        document.getElementById(modalId).classList.remove('show');
    }

    // ============================================
    // PRODUCTS
    // ============================================
    async function loadProducts() {
        try {
            const response = await fetch('/api/admin/products');
            const data = await response.json();
            const tbody = document.getElementById('productsTableBody');
            
            if (data.success && data.products && data.products.length > 0) {
                tbody.innerHTML = data.products.map(p => `
                    <tr>
                        <td><img src="${p.image || 'product.jpeg'}" class="product-img-thumb" onerror="this.src='product.jpeg'"></td>
                        <td><strong>${p.name}</strong><br><small style="color: #64748b;">${p.sku || 'No SKU'}</small></td>
                        <td style="color: #facc15;">₹${p.price.toFixed(2)}</td>
                        <td><span class="status-badge ${p.stock > 20 ? 'status-active' : p.stock > 0 ? 'status-low-stock' : 'status-inactive'}">${p.stock > 20 ? 'In Stock' : p.stock > 0 ? 'Low Stock' : 'Out of Stock'}</span></td>
                        <td style="color: #94a3b8;">${p.category || 'General'}</td>
                        <td><span class="status-badge ${p.status === 'active' ? 'status-active' : 'status-inactive'}">${p.status || 'active'}</span></td>
                        <td>
                            <button class="btn-warning" onclick="editProduct('${p.id}')" style="padding: 4px 12px; font-size: 12px; margin-right: 5px;"><i class="fas fa-edit"></i></button>
                            <button class="btn-danger" onclick="deleteProduct('${p.id}')" style="padding: 4px 12px; font-size: 12px;"><i class="fas fa-trash"></i></button>
